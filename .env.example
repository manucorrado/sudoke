# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sudoke

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

# Clerk Auth
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Sentry
SENTRY_DSN=

# API
API_V1_PREFIX=/api/v1

# Comma-separated browser origins allowed by CORS outside development.
CORS_ALLOWED_ORIGINS=

# Honor the X-Dev-Auth-User bypass header outside development (staging only).
ADMIN_DEV_BYPASS_ENABLED=false
