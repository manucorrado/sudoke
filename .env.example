# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sudoke

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=

# Clerk Auth
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_AUDIENCE=
CLERK_WEBHOOK_SIGNING_SECRET=

# Sentry
SENTRY_DSN=

# Analytics / notifications (optional until Epic 8/10 final mile)
POSTHOG_API_KEY=
POSTHOG_HOST=
# Server-side push (Epic 8). EXPO_PUSH_ENABLED gates dispatch; leave false
# until APNs/FCM + an Expo project are wired (registration still works and
# dispatch is a safe no-op while off). EXPO_ACCESS_TOKEN is the optional
# Expo Push bearer used only when delivery is enabled.
EXPO_PUSH_ENABLED=false
EXPO_ACCESS_TOKEN=

# API
API_V1_PREFIX=/api/v1
CHALLENGE_SHARE_BASE_URL=https://sudoke.app/c

# Mobile / Expo
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CHALLENGE_WEB_BASE_URL=http://localhost:8081/c
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=

# Admin
API_BASE_URL=http://localhost:8000/api/v1
ADMIN_AUTH_PROVIDER_ID=admin-dev
ADMIN_API_BEARER=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Comma-separated browser origins allowed by CORS outside development.
CORS_ALLOWED_ORIGINS=

# Honor the X-Dev-Auth-User bypass header outside development (staging only).
ADMIN_DEV_BYPASS_ENABLED=false
