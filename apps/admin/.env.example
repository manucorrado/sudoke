# API
API_BASE_URL=http://localhost:8000/api/v1

# Development only: FastAPI honors this header only when ENVIRONMENT=development.
ADMIN_AUTH_PROVIDER_ID=admin-dev

# Staging/production: use a real Clerk session/service token server-side.
ADMIN_API_BEARER=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Runtime
NODE_ENV=development
