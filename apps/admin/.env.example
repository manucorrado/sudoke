# Sudoke Admin — environment variables
#
# Copy to .env.local for local development. In Render these are set on the
# sudoke-admin service (see render.yaml).

# Base URL of the Sudoke API, including the version prefix.
# Local:   http://localhost:8000/api/v1
# Staging: internal Render URL of sudoke-api-staging, e.g.
#          http://sudoke-api-staging:10000/api/v1
API_BASE_URL=http://localhost:8000/api/v1

# Deployment environment: development | staging | production
ENVIRONMENT=development

# Principal sent via the X-Dev-Auth-User bypass header. Only honored by the
# API in development, or in staging when ADMIN_DEV_BYPASS_ENABLED=true.
# Replace with a real Clerk session once auth is wired (INFRA_EPICS I6).
ADMIN_AUTH_PROVIDER_ID=admin-dev

# Optional server-side bearer token forwarded to the API as Authorization.
# Never expose as NEXT_PUBLIC_*.
ADMIN_API_BEARER=
