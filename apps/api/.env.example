# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sudoke

# Redis
REDIS_URL=redis://localhost:6379/0

# Sentry (optional)
SENTRY_DSN=

# Clerk Auth (optional)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_JWT_AUDIENCE=
CLERK_WEBHOOK_SIGNING_SECRET=

# App
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=
CHALLENGE_SHARE_BASE_URL=https://sudoke.app/c

# Analytics / notifications (optional until Epic 8/10 final mile)
POSTHOG_API_KEY=
POSTHOG_HOST=
# Server-side push (Epic 8). EXPO_PUSH_ENABLED gates dispatch; leave false
# until APNs/FCM + an Expo project are wired (registration still works and
# dispatch is a safe no-op while off). EXPO_ACCESS_TOKEN is the optional
# Expo Push bearer used only when delivery is enabled.
EXPO_PUSH_ENABLED=false
EXPO_ACCESS_TOKEN=

# Comma-separated browser origins allowed by CORS outside development
# (e.g. the admin dashboard or Expo web). Native mobile clients are not
# CORS-gated. Ignored in development, where all origins are allowed.
CORS_ALLOWED_ORIGINS=

# Honor the X-Dev-Auth-User bypass header outside development. Keep false
# in production; may be enabled in staging until Clerk auth is wired.
ADMIN_DEV_BYPASS_ENABLED=false
