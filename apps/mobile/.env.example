# Local development
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_CHALLENGE_WEB_BASE_URL=http://localhost:8081/c

# Staging/production
# EXPO_PUBLIC_ENVIRONMENT=staging
# EXPO_PUBLIC_API_BASE_URL=https://api.staging.sudoke.app/api/v1
# EXPO_PUBLIC_CHALLENGE_WEB_BASE_URL=https://staging.sudoke.app/c
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional until Epic 10 / Epic 8 final mile
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
# Sudoke Mobile — environment variables
#
# Copy to .env for local development. Expo only exposes variables prefixed
# with EXPO_PUBLIC_ to the app bundle.

# Base URL of the Sudoke API, including the version prefix.
# Local:   http://localhost:8000/api/v1
# Staging: https://<sudoke-api-staging public URL>/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
