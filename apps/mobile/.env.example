# Sudoke Mobile — environment variables
#
# Copy to .env for local development. Expo only exposes variables prefixed
# with EXPO_PUBLIC_ to the app bundle.

# Base URL of the Sudoke API, including the version prefix.
# Local:   http://localhost:8000/api/v1
# Staging: https://<sudoke-api-staging public URL>/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
