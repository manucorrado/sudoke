{
  "expo": {
    "name": "Sudoke",
    "slug": "sudoke",
    "scheme": "sudoke",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sudoke.app"
    },
    "android": {
      "package": "com.sudoke.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@sentry/react-native",
      "expo-asset"
    ]
  }
}
